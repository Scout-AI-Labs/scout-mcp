  "author": "Scout AI Labs",
  "license": "MIT",
  "homepage": "https://usescout.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Scout-AI-Labs/scout-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
