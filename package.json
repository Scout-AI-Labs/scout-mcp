{
  "name": "@scout-ai/mcp",
  "version": "0.1.0",
  "description": "Scout MCP server: web search, scraping, extraction, and crawling tools for Claude Code, Codex, Gemini CLI, Antigravity, Cursor, and any MCP client",
  "type": "module",
  "bin": {
    "scout-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
